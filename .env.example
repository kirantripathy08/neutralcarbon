# NeutralCarbon — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Blockchain ─────────────────────────────────────────────────────────────
# Your wallet private key (for deployment — use a dedicated deployer wallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URLs
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# CoinMarketCap API key (for gas price reporting in USD)
COINMARKETCAP_API_KEY=YOUR_CMC_API_KEY

# ── Chainlink ──────────────────────────────────────────────────────────────
CHAINLINK_JOB_ID=ca98366cc7314957b8c012c72f05aeeb
CHAINLINK_FEE_LINK=100000000000000000  # 0.1 LINK in wei

# ── QML API ────────────────────────────────────────────────────────────────
# Base URL for the off-chain QML verification API (called by Chainlink)
QML_API_URL=https://api.neutralcarbon.io/verify

# ── Dashboard / Flask API ─────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change-this-to-a-random-string

# ── Data ───────────────────────────────────────────────────────────────────
DATA_PATH=data/global_emissions.csv
ARTIFACTS_DIR=ml/artifacts
